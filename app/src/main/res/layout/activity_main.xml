<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Mapa de Google Maps -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Panel superior con controles -->
    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#CC000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Botón para seleccionar ciudad -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectCity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="Ciudad"
            android:textSize="12sp"
            app:icon="@android:drawable/ic_dialog_map"
            app:iconSize="18dp"
            style="@style/Widget.Material3.Button.TonalButton" />

        <!-- Botón para buscar rutas -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSearchRoutes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="Rutas"
            android:textSize="12sp"
            app:icon="@android:drawable/ic_menu_search"
            app:iconSize="18dp"
            style="@style/Widget.Material3.Button.TonalButton" />

        <!-- Botón para cambiar tipo de mapa -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMapType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="Mapa"
            android:textSize="12sp"
            app:icon="@android:drawable/ic_menu_mapmode"
            app:iconSize="18dp"
            style="@style/Widget.Material3.Button.TonalButton" />

    </LinearLayout>

    <!-- Panel inferior con origen/destino -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardElevation="8dp"
        app:cardCornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Origen -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/presence_online"
                    android:contentDescription="Origen"
                    app:tint="#4CAF50" />

                <TextView
                    android:id="@+id/tvOrigen"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Seleccionar origen"
                    android:textSize="14sp"
                    android:textColor="?android:textColorPrimary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSelectOrigen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seleccionar"
                    android:textSize="12sp"
                    style="@style/Widget.Material3.Button.TextButton" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="8dp"
                android:background="?android:attr/listDivider" />

            <!-- Destino -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/presence_busy"
                    android:contentDescription="Destino"
                    app:tint="#F44336" />

                <TextView
                    android:id="@+id/tvDestino"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Seleccionar destino"
                    android:textSize="14sp"
                    android:textColor="?android:textColorPrimary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSelectDestino"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seleccionar"
                    android:textSize="12sp"
                    style="@style/Widget.Material3.Button.TextButton" />

            </LinearLayout>

            <!-- Botón de intercambiar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSwapLocations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Intercambiar"
                android:textSize="12sp"
                app:icon="@android:drawable/ic_menu_revert"
                app:iconSize="18dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
